# Supabase Postgres — use the TRANSACTION-MODE POOLER, not the direct host.
# The direct host (db.<ref>.supabase.co:5432) is IPv6-only and often unreachable;
# the pooler is required (db-schema §6.5). Note the user is `postgres.<ref>` and
# the port is 6543. The app disables asyncpg's statement cache for PgBouncer.
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# LLM (only read inside ai_reasoning/ — build rule 3). Unused until Phase 5.
LLM_PROVIDER=openai
LLM_API_KEY=

# CORS: comma-separated browser origins allowed to call the API (the public
# Goal Simulator is a cross-origin call from the Next site). Defaults to the
# local dev origins; set your real deploy origin(s) here in production.
# Never use "*" — the API is CORS-scoped on purpose.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Supabase Auth: the project JWT secret (Supabase dashboard → Settings → API →
# JWT Secret). Used to verify the access token the frontend session sends on
# authenticated endpoints (/goals/recommendation/save). Empty ⇒ auth is
# DISABLED and those endpoints reject every request (fail closed).
SUPABASE_JWT_SECRET=
